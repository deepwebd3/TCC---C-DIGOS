def runge_kutta_4(f, x0, y0, h, n):
    """
    Método de Runge-Kutta de 4ª ordem (RK4)
    """
    x_vals = [x0]
    y_vals = [y0]
    
    x, y = x0, y0
    for i in range(n):
        k1 = f(x, y)
        k2 = f(x + h/2, y + h*k1/2)
        k3 = f(x + h/2, y + h*k2/2)
        k4 = f(x + h, y + h*k3)
        y = y + (h/6)*(k1 + 2*k2 + 2*k3 + k4)
        x = x + h
        x_vals.append(x)
        y_vals.append(y)
    return x_vals, y_vals