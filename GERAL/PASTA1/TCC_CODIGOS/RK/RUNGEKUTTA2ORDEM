def runge_kutta_2(f, x0, y0, h, n):
    """
    Método de Runge-Kutta de 2ª ordem (RK2 ou Heun)
    """
    x_vals = [x0]
    y_vals = [y0]
    
    x, y = x0, y0
    for i in range(n):
        k1 = f(x, y)
        k2 = f(x + h, y + h * k1)
        y = y + (h/2) * (k1 + k2)
        x = x + h
        x_vals.append(x)
        y_vals.append(y)
    return x_vals, y_vals
