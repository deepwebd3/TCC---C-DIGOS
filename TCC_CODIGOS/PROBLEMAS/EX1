from typing import Callable, Tuple

def _solve_ode(f: Callable[[float, float], float], x0: float, y0: float, h: float, n: int, rk_step: Callable) -> Tuple[np.ndarray, np.ndarray]:
    """
    General solver for ODEs using Runge-Kutta methods.

    Args:
        f: The function representing the ODE, dy/dx = f(x, y).
        x0: Initial value of x.
        y0: Initial value of y.
        h: Step size.
        n: Number of steps.
        rk_step: A callable that computes the next y value based on the specific RK method.

    Returns:
        A tuple containing two numpy arrays:
        - xs: Array of x values.
        - ys: Array of y values.
    """
    x, y = x0, y0
    xs, ys = [x], [y]
    for _ in range(n):
        y = rk_step(f, x, y, h)
        x += h
        xs.append(x)
        ys.append(y)
    return np.array(xs), np.array(ys)

def rk1(f: Callable[[float, float], float], x0: float, y0: float, h: float, n: int) -> Tuple[np.ndarray, np.ndarray]:
    """
    Solves an ODE using the Euler (RK1) method.

    Args:
        f: The function representing the ODE, dy/dx = f(x, y).
        x0: Initial value of x.
        y0: Initial value of y.
        h: Step size.
        n: Number of steps.

    Returns:
        A tuple containing two numpy arrays:
        - xs: Array of x values.
        - ys: Array of y values.
    """
    def rk1_step(f, x, y, h):
        return y + h * f(x, y)
    return _solve_ode(f, x0, y0, h, n, rk1_step)

def rk2(f: Callable[[float, float], float], x0: float, y0: float, h: float, n: int) -> Tuple[np.ndarray, np.ndarray]:
    """
    Solves an ODE using the Runge-Kutta 2nd order method (Heun's method).

    Args:
        f: The function representing the ODE, dy/dx = f(x, y).
        x0: Initial value of x.
        y0: Initial value of y.
        h: Step size.
        n: Number of steps.

    Returns:
        A tuple containing two numpy arrays:
        - xs: Array of x values.
        - ys: Array of y values.
    """
    def rk2_step(f, x, y, h):
        k1 = f(x, y)
        k2 = f(x + h, y + h*k1)
        return y + (h/2)*(k1 + k2)
    return _solve_ode(f, x0, y0, h, n, rk2_step)

def rk3(f: Callable[[float, float], float], x0: float, y0: float, h: float, n: int) -> Tuple[np.ndarray, np.ndarray]:
    """
    Solves an ODE using the Runge-Kutta 3rd order method.

    Args:
        f: The function representing the ODE, dy/dx = f(x, y).
        x0: Initial value of x.
        y0: Initial value of y.
        h: Step size.
        n: Number of steps.

    Returns:
        A tuple containing two numpy arrays:
        - xs: Array of x values.
        - ys: Array of y values.
    """
    def rk3_step(f, x, y, h):
        k1 = f(x, y)
        k2 = f(x + h/2, y + h*k1/2)
        k3 = f(x + h, y - h*k1 + 2*h*k2)
        return y + (h/6)*(k1 + 4*k2 + k3)
    return _solve_ode(f, x0, y0, h, n, rk3_step)

def rk4(f: Callable[[float, float], float], x0: float, y0: float, h: float, n: int) -> Tuple[np.ndarray, np.ndarray]:
    """
    Solves an ODE using the Runge-Kutta 4th order method.

    Args:
        f: The function representing the ODE, dy/dx = f(x, y).
        x0: Initial value of x.
        y0: Initial value of y.
        h: Step size.
        n: Number of steps.

    Returns:
        A tuple containing two numpy arrays:
        - xs: Array of x values.
        - ys: Array of y values.
    """
    def rk4_step(f, x, y, h):
        k1 = f(x, y)
        k2 = f(x + h/2, y + h*k1/2)
        k3 = f(x + h/2, y + h*k2/2)
        k4 = f(x + h, y + h*k3)
        return y + (h/6)*(k1 + 2*k2 + 2*k3 + k4)
    return _solve_ode(f, x0, y0, h, n, rk4_step)

