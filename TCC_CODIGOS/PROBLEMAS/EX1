V0 = 3.0e4
C  = 500e-12
R  = 25e9
U_fogo = 50e-3
tau = R * C


def f(t: float, V: float) -> float:
    """
    Defines the differential equation for the problem.

    Args:
        t: Time.
        V: Voltage.

    Returns:
        The derivative of V with respect to t.
    """
    return -V / tau

def V_analytic(t: float) -> float:
    """
    Calculates the analytical solution for the voltage at a given time.

    Args:
        t: Time.

    Returns:
        Analytical voltage at time t.
    """
    return V0 * np.exp(-t / tau)

def print_results_table(h_list: list, t_max: float, metodos: dict,
                        f: Callable[[float, float], float], V_analytic: Callable[[float], float],
                        V0: float, C: float, U_fogo: float, tau: float):
    """
    Prints a formatted table of numerical simulation results.
    """
    print("\nANÁLISE DE CONVERGÊNCIA – VARIAÇÃO DO PASSO h\n")
    print(f"{'h':<8} | {'Método':<6} | {'Tempo Numérico (s)':>20} | {'Erro Relativo Médio':>22}")
    print("-"*70)

    for h in h_list:
        n = int(t_max / h)

        for nome, metodo in metodos.items():
            t_vals, V_vals = metodo(f, 0.0, V0, h, n)
            U_vals = 0.5 * C * V_vals**2

            # Cruzamento da energia
            idx = np.where(U_vals < U_fogo)[0]
            if len(idx) > 0 and idx[0] > 0:
                i = idx[0]
                t1, t2 = t_vals[i-1], t_vals[i]
                U1, U2 = U_vals[i-1], U_vals[i]

                # Handle division by zero if U2 - U1 is very small
                if abs(U2 - U1) < np.finfo(float).eps:
                    frac = 0.0  # Or handle as an error/specific case
                else:
                    frac = (U_fogo - U1) / (U2 - U1)

                t_num = t1 + frac * (t2 - t1)
            else:
                t_num = np.nan

            # Erro relativo médio
            V_ex = V_analytic(t_vals)
            eps = np.finfo(float).eps
            erro = np.mean(np.abs((V_vals - V_ex) / np.maximum(np.abs(V_ex), eps)))

            print(f"{h:<8.3e} | {nome:<6} | {t_num:>20.8f} | {erro:>22.6e}")

        print("-"*70)


